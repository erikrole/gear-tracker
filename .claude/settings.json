{
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "code-review@claude-code-plugins": true,
    "vercel-plugin@claude-code-plugins": true
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(chmod -R 777 *)",
      "Bash(chmod +777 *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Bash(eval *)",
      "Bash(sudo *)",
      "Bash(ssh *)",
      "Bash(dd * of=/dev/*)",
      "Bash(* > /dev/*)",
      "Bash(tee /dev/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && jq -r '\"[PreToolUse] \" + .tool_name + \": \" + (.tool_input.command // \"\")[:120]' >> ~/.claude/logs/bash-audit.log; exit 0"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(jq -r '.tool_input.file_path // empty'); case \"$FILE\" in *.ts|*.tsx) ;; *) exit 0;; esac; cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null || exit 0; OUT=$(npx --no-install tsc --noEmit -p tsconfig.json 2>&1 | tail -20); if echo \"$OUT\" | grep -q 'error TS'; then echo '[tsc advisory] type errors after edit (non-blocking, run npm run build before commit):'; echo \"$OUT\"; fi; exit 0",
            "async": true,
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p ~/.claude/logs && echo \"[Stop] Session ended at $(date -u +%Y-%m-%dT%H:%M:%SZ)\" >> ~/.claude/logs/bash-audit.log; exit 0"
          }
        ]
      }
    ]
  }
}

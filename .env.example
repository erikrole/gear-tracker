# ============================================================
# Gear Tracker — Environment Variables
# ============================================================
# Copy to .env.local and fill in values for local development.

# ── Required ──────────────────────────────────────────────

# Pooled PostgreSQL connection string for the application runtime (Neon pooler)
DATABASE_URL="postgresql://user:password@ep-example-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Direct PostgreSQL connection string for Prisma CLI migrations and introspection
DIRECT_URL="postgresql://user:password@ep-example.region.aws.neon.tech/dbname?sslmode=require"

# Session security
SESSION_SECRET="generate-a-random-64-char-string"
SESSION_COOKIE_NAME="gear-tracker-session"

# ── Optional (Production Features) ────────────────────────

# Vercel Cron — secures /api/cron/* endpoints
# CRON_SECRET=""

# Public production URL used for generated links, email actions, and app handoffs
# APP_URL="https://wisconsincreative.com"

# Optional comma-separated override for CSRF origin checks. When unset, runtime
# trusts APP_URL plus the Wisconsin Creative canonical and rollout legacy hosts.
# TRUSTED_ORIGINS="https://wisconsincreative.com"

# Resend — enables email delivery (falls back to console.log)
# RESEND_API_KEY=""
# EMAIL_FROM="Wisconsin Creative <noreply@wisconsincreative.com>"

# Sentry — error tracking (app works fine without)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""

# Vercel Blob — enables image uploads on asset pages
# BLOB_READ_WRITE_TOKEN=""

# Product Image Search. Optional. Brave is the default provider.
# BRAVE_SEARCH_API_KEY=""

# Upstash Redis — durable, cross-instance API rate limiting (provision via
# Vercel Marketplace). When unset, rate limiting falls back to per-instance
# in-memory counters. KV_REST_API_URL / KV_REST_API_TOKEN are also accepted.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Student badge achievements — default off until rollout verification passes
# BADGES_ENABLED="false"

# Internal maintenance operators who may opt into hidden smoke/test identities
# in production tools. Comma-separated email addresses.
# INTERNAL_OPERATOR_EMAILS="owner@example.com"

# ── Optional (Build / CI) ────────────────────────────────

# Sentry source map uploads (set in Vercel environment)
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# Bundle analyzer (set to "true" to generate report)
# ANALYZE=""

# ── Optional (Customization) ─────────────────────────────

# Timezone for date calculations (default: America/Chicago)
# APP_TIMEZONE="America/Chicago"

# ── Scripts Only ──────────────────────────────────────────

# Initial admin account password for prisma/seed.mjs and the /api/seed endpoint.
# REQUIRED in production when the seed endpoint runs — it refuses to fall back to
# a default password there. Development uses a known default if this is unset.
# SEED_ADMIN_PASSWORD="ChangeMeNow123!"

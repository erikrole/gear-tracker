generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
  STUDENT
}

enum AssetStatus {
  AVAILABLE
  MAINTENANCE
  RETIRED
}

enum BookingKind {
  RESERVATION
  CHECKOUT
}

enum BookingStatus {
  DRAFT
  BOOKED
  PENDING_PICKUP
  OPEN
  COMPLETED
  CANCELLED
}

enum AllocationKind {
  RESERVATION
  CHECKOUT
}

enum BulkMovementKind {
  CHECKOUT
  CHECKIN
  ADJUSTMENT
}

enum ScanType {
  SERIALIZED
  BULK_BIN
}

enum ScanPhase {
  CHECKOUT
  CHECKIN
}

enum BulkUnitStatus {
  AVAILABLE
  CHECKED_OUT
  LOST
  RETIRED
}

enum ScanSessionStatus {
  OPEN
  COMPLETED
  CANCELLED
}

enum CheckinReportType {
  DAMAGED
  LOST
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  passwordHash   String       @map("password_hash")
  role           Role
  active         Boolean      @default(true)
  phone          String?
  avatarUrl      String?      @map("avatar_url")
  primaryArea    ShiftArea?   @map("primary_area")
  locationId     String?      @map("location_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  location       Location?    @relation(fields: [locationId], references: [id], onDelete: SetNull)
  sessions       Session[]
  requested      Booking[]    @relation("BookingRequester")
  createdBookings Booking[]   @relation("BookingCreator")
  scanEvents     ScanEvent[]
  scanSessions   ScanSession[]
  overrides      OverrideEvent[]
  bulkMovements  BulkStockMovement[]
  audits         AuditLog[]   @relation("AuditActor")
  shiftAssignments    ShiftAssignment[]  @relation("ShiftAssignee")
  shiftAssignedBy     ShiftAssignment[]  @relation("ShiftAssigner")
  sportAssignments    StudentSportAssignment[]
  areaAssignments     StudentAreaAssignment[]
  tradesPosted        ShiftTrade[]       @relation("TradePostedBy")
  tradesClaimed       ShiftTrade[]       @relation("TradeClaimedBy")
  favorites           FavoriteItem[]
  passwordResetTokens PasswordResetToken[]
  notifications       Notification[]
  deviceTokens        DeviceToken[]
  bookingPhotos       BookingPhoto[]     @relation("BookingPhotoActor")
  checkinReports      CheckinItemReport[] @relation("CheckinReports")
  allowedEmailsCreated AllowedEmail[]    @relation("AllowedEmailCreator")
  allowedEmailsClaimed AllowedEmail[]    @relation("AllowedEmailClaimer")
  licenseCodesHeld     LicenseCode[]     @relation("LicenseClaimedBy")
  licenseCodesCreated  LicenseCode[]     @relation("LicenseCreatedBy")
  licenseClaims        LicenseCodeClaim[]
  guides               Guide[]
  availabilityBlocks   StudentAvailabilityBlock[]
  travelMemberships    EventTravelMember[]        @relation("TravelMembers")

  @@map("users")
}

model Session {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Location {
  id             String      @id @default(cuid())
  name           String      @unique
  address        String?
  active         Boolean     @default(true)
  isHomeVenue    Boolean     @default(false) @map("is_home_venue")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  users          User[]
  assets         Asset[]
  bookings       Booking[]
  bulkSkus       BulkSku[]
  bulkBalances   BulkStockBalance[]
  bulkMovements  BulkStockMovement[]
  kits           Kit[]
  calendarEvents CalendarEvent[]
  locationMappings LocationMapping[]
  kioskDevices   KioskDevice[]

  @@map("locations")
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  assets    Asset[]
  bulkSkus  BulkSku[]

  @@map("departments")
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?    @map("parent_id")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  assets    Asset[]
  bulkSkus  BulkSku[]

  @@unique([name, parentId])
  @@index([parentId])
  @@map("categories")
}

model Asset {
  id               String                   @id @default(cuid())
  assetTag         String                   @unique @map("asset_tag")
  name             String?
  type             String
  brand            String
  model            String
  serialNumber     String?                  @unique @map("serial_number")
  qrCodeValue      String                   @unique @map("qr_code_value")
  primaryScanCode  String?                  @unique @map("primary_scan_code")
  purchaseDate     DateTime?                @map("purchase_date")
  purchasePrice    Decimal?                 @db.Decimal(10, 2) @map("purchase_price")
  warrantyDate     DateTime?                @map("warranty_date")
  residualValue    Decimal?                 @db.Decimal(10, 2) @map("residual_value")
  locationId       String                   @map("location_id")
  departmentId     String?                  @map("department_id")
  categoryId       String?                  @map("category_id")
  status           AssetStatus              @default(AVAILABLE)
  consumable       Boolean                  @default(false)
  availableForReservation Boolean            @default(true) @map("available_for_reservation")
  availableForCheckout    Boolean            @default(true) @map("available_for_checkout")
  availableForCustody     Boolean            @default(true) @map("available_for_custody")
  linkUrl          String?                  @map("link_url")
  imageUrl         String?                  @map("image_url")
  uwAssetTag       String?                  @map("uw_asset_tag")
  notes            String?
  sourcePayload    Json?                    @map("source_payload")
  createdAt        DateTime                 @default(now()) @map("created_at")
  updatedAt        DateTime                 @updatedAt @map("updated_at")
  location         Location                 @relation(fields: [locationId], references: [id], onDelete: Restrict)
  department       Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  category         Category?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  parentAssetId    String?                  @map("parent_asset_id")
  parent           Asset?                   @relation("AssetAccessories", fields: [parentAssetId], references: [id], onDelete: SetNull)
  accessories      Asset[]                  @relation("AssetAccessories")
  bookingItems     BookingSerializedItem[]
  allocations      AssetAllocation[]
  scans            ScanEvent[]
  kitMemberships   KitMembership[]
  favoritedBy      FavoriteItem[]
  checkinReports   CheckinItemReport[]

  @@index([locationId])
  @@index([departmentId])
  @@index([categoryId])
  @@index([brand, model])
  @@index([status])
  @@index([parentAssetId])
  @@map("assets")
}

model Booking {
  id                String                  @id @default(cuid())
  kind              BookingKind
  title             String
  requesterUserId   String                  @map("requester_user_id")
  locationId        String                  @map("location_id")
  startsAt          DateTime                @map("starts_at")
  endsAt            DateTime                @map("ends_at")
  status            BookingStatus
  createdBy         String                  @map("created_by")
  notes             String?
  sourceReservationId String?               @map("source_reservation_id")
  eventId           String?                 @map("event_id")
  sportCode           String?                 @map("sport_code")
  refNumber           String?                 @unique @map("ref_number")
  shiftAssignmentId   String?                 @map("shift_assignment_id")
  kitId               String?                 @map("kit_id")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  requester           User                    @relation("BookingRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  creator             User                    @relation("BookingCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  location            Location                @relation(fields: [locationId], references: [id], onDelete: Restrict)
  sourceReservation   Booking?                @relation("CheckoutFromReservation", fields: [sourceReservationId], references: [id], onDelete: SetNull)
  derivedCheckouts    Booking[]               @relation("CheckoutFromReservation")
  event               CalendarEvent?          @relation(fields: [eventId], references: [id], onDelete: SetNull)
  shiftAssignment     ShiftAssignment?        @relation(fields: [shiftAssignmentId], references: [id], onDelete: SetNull)
  kit                 Kit?                    @relation(fields: [kitId], references: [id], onDelete: SetNull)
  events              BookingEvent[]
  serializedItems     BookingSerializedItem[]
  bulkItems           BookingBulkItem[]
  allocations         AssetAllocation[]
  scanEvents          ScanEvent[]
  scanSessions        ScanSession[]
  overrides           OverrideEvent[]
  bulkMovements       BulkStockMovement[]
  photos              BookingPhoto[]
  checkinReports      CheckinItemReport[]

  @@index([locationId, startsAt, endsAt])
  @@index([status, kind])
  @@index([sourceReservationId])
  @@index([eventId])
  @@index([sportCode])
  @@index([shiftAssignmentId])
  @@index([requesterUserId])
  @@index([kitId])
  @@index([kind, status, endsAt])
  @@index([kind, status, requesterUserId, endsAt])
  @@index([startsAt, endsAt])
  @@index([createdBy, status])
  @@map("bookings")
}

model BookingSerializedItem {
  id                String   @id @default(cuid())
  bookingId         String   @map("booking_id")
  assetId           String   @map("asset_id")
  allocationStatus  String   @default("active") @map("allocation_status")
  createdAt         DateTime @default(now()) @map("created_at")
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@unique([bookingId, assetId])
  @@index([assetId])
  @@map("booking_serialized_items")
}

model BookingBulkItem {
  id                 String                      @id @default(cuid())
  bookingId          String                      @map("booking_id")
  bulkSkuId          String                      @map("bulk_sku_id")
  plannedQuantity    Int                         @map("planned_quantity")
  checkedOutQuantity Int                         @default(0) @map("checked_out_quantity")
  checkedInQuantity  Int                         @default(0) @map("checked_in_quantity")
  createdAt          DateTime                    @default(now()) @map("created_at")
  booking            Booking                     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bulkSku            BulkSku                     @relation(fields: [bulkSkuId], references: [id], onDelete: Restrict)
  unitAllocations    BookingBulkUnitAllocation[]

  @@unique([bookingId, bulkSkuId])
  @@index([bulkSkuId])
  @@map("booking_bulk_items")
}

model AssetAllocation {
  id                String         @id @default(cuid())
  assetId           String         @map("asset_id")
  bookingId         String         @map("booking_id")
  startsAt          DateTime       @map("starts_at")
  endsAt            DateTime       @map("ends_at")
  active            Boolean        @default(true)
  kind              AllocationKind
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  asset             Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  booking           Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([assetId, active])
  @@index([assetId, active, startsAt, endsAt])
  @@index([bookingId])
  @@map("asset_allocations")
}

model BulkSku {
  id                String             @id @default(cuid())
  name              String
  category          String
  unit              String
  locationId        String             @map("location_id")
  categoryId        String?            @map("category_id")
  departmentId      String?            @map("department_id")
  binQrCodeValue    String             @map("bin_qr_code_value")
  minThreshold      Int                @default(0) @map("min_threshold")
  trackByNumber     Boolean            @default(false) @map("track_by_number")
  purchasePrice     Decimal?           @db.Decimal(10, 2) @map("purchase_price")
  purchaseLink      String?            @map("purchase_link")
  notes             String?
  imageUrl          String?            @map("image_url")
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  location          Location           @relation(fields: [locationId], references: [id], onDelete: Restrict)
  categoryRel       Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  department        Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  balances          BulkStockBalance[]
  movements         BulkStockMovement[]
  bookingItems      BookingBulkItem[]
  scans             ScanEvent[]
  units             BulkSkuUnit[]
  kitBulkMembers    KitBulkMembership[]

  @@unique([locationId, binQrCodeValue])
  @@index([locationId, active])
  @@index([categoryId])
  @@index([departmentId])
  @@map("bulk_skus")
}

model BulkStockBalance {
  id                String    @id @default(cuid())
  bulkSkuId         String    @map("bulk_sku_id")
  locationId        String    @map("location_id")
  onHandQuantity    Int       @default(0) @map("on_hand_quantity")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  bulkSku           BulkSku   @relation(fields: [bulkSkuId], references: [id], onDelete: Cascade)
  location          Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@unique([bulkSkuId, locationId])
  @@index([locationId])
  @@map("bulk_stock_balances")
}

model BulkStockMovement {
  id                String           @id @default(cuid())
  bulkSkuId         String           @map("bulk_sku_id")
  locationId        String           @map("location_id")
  bookingId         String?          @map("booking_id")
  actorUserId       String           @map("actor_user_id")
  kind              BulkMovementKind
  quantity          Int
  reason            String?
  createdAt         DateTime         @default(now()) @map("created_at")
  bulkSku           BulkSku          @relation(fields: [bulkSkuId], references: [id], onDelete: Restrict)
  location          Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  booking           Booking?         @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  actor             User             @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([bulkSkuId, createdAt])
  @@index([bookingId])
  @@index([actorUserId])
  @@map("bulk_stock_movements")
}

// ── Numbered Bulk Unit Tracking ──────────────────────────

model BulkSkuUnit {
  id             String         @id @default(cuid())
  bulkSkuId      String         @map("bulk_sku_id")
  unitNumber     Int            @map("unit_number")
  status         BulkUnitStatus @default(AVAILABLE)
  notes          String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  bulkSku        BulkSku        @relation(fields: [bulkSkuId], references: [id], onDelete: Cascade)
  allocations    BookingBulkUnitAllocation[]

  @@unique([bulkSkuId, unitNumber])
  @@index([bulkSkuId, status])
  @@map("bulk_sku_units")
}

model BookingBulkUnitAllocation {
  id                String         @id @default(cuid())
  bookingBulkItemId String         @map("booking_bulk_item_id")
  bulkSkuUnitId     String         @map("bulk_sku_unit_id")
  checkedOutAt      DateTime?      @map("checked_out_at")
  checkedInAt       DateTime?      @map("checked_in_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  bookingBulkItem   BookingBulkItem @relation(fields: [bookingBulkItemId], references: [id], onDelete: Cascade)
  bulkSkuUnit       BulkSkuUnit    @relation(fields: [bulkSkuUnitId], references: [id], onDelete: Restrict)

  @@unique([bookingBulkItemId, bulkSkuUnitId])
  @@index([bulkSkuUnitId])
  @@map("booking_bulk_unit_allocations")
}

model ScanEvent {
  id                String    @id @default(cuid())
  bookingId         String    @map("booking_id")
  actorUserId       String    @map("actor_user_id")
  scanType          ScanType  @map("scan_type")
  scanValue         String    @map("scan_value")
  success           Boolean
  phase             ScanPhase
  assetId           String?   @map("asset_id")
  bulkSkuId         String?   @map("bulk_sku_id")
  quantity          Int?
  deviceContext     String?   @map("device_context")
  createdAt         DateTime  @default(now()) @map("created_at")
  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor             User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)
  asset             Asset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  bulkSku           BulkSku?  @relation(fields: [bulkSkuId], references: [id], onDelete: SetNull)

  @@index([bookingId, phase])
  @@index([scanValue])
  @@index([actorUserId])
  @@map("scan_events")
}

model ScanSession {
  id                String            @id @default(cuid())
  bookingId         String            @map("booking_id")
  actorUserId       String            @map("actor_user_id")
  phase             ScanPhase
  status            ScanSessionStatus @default(OPEN)
  startedAt         DateTime          @default(now()) @map("started_at")
  completedAt       DateTime?         @map("completed_at")
  booking           Booking           @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor             User              @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([bookingId, phase, status])
  @@map("scan_sessions")
}

model OverrideEvent {
  id                String    @id @default(cuid())
  bookingId         String    @map("booking_id")
  actorUserId       String    @map("actor_user_id")
  reason            String
  details           Json?
  createdAt         DateTime  @default(now()) @map("created_at")
  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor             User      @relation(fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([bookingId, createdAt])
  @@index([actorUserId])
  @@map("override_events")
}

model AuditLog {
  id                String    @id @default(cuid())
  actorUserId       String?   @map("actor_user_id")
  entityType        String    @map("entity_type")
  entityId          String    @map("entity_id")
  action            String
  beforeJson        Json?     @map("before_json")
  afterJson         Json?     @map("after_json")
  createdAt         DateTime  @default(now()) @map("created_at")
  actor             User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}

// ── Kit / Case grouping ──────────────────────────────────

model Kit {
  id          String              @id @default(cuid())
  name        String
  description String?
  locationId  String              @map("location_id")
  active      Boolean             @default(true)
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  location    Location            @relation(fields: [locationId], references: [id], onDelete: Restrict)
  members     KitMembership[]
  bulkMembers KitBulkMembership[]
  bookings    Booking[]

  @@unique([name, locationId])
  @@map("kits")
}

model KitMembership {
  id        String   @id @default(cuid())
  kitId     String   @map("kit_id")
  assetId   String   @map("asset_id")
  createdAt DateTime @default(now()) @map("created_at")
  kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([kitId, assetId])
  @@map("kit_memberships")
}

model KitBulkMembership {
  id        String   @id @default(cuid())
  kitId     String   @map("kit_id")
  bulkSkuId String   @map("bulk_sku_id")
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")
  kit       Kit      @relation(fields: [kitId], references: [id], onDelete: Cascade)
  bulkSku   BulkSku  @relation(fields: [bulkSkuId], references: [id], onDelete: Cascade)

  @@unique([kitId, bulkSkuId])
  @@index([bulkSkuId])
  @@map("kit_bulk_memberships")
}

// ── ICS Calendar Sync ────────────────────────────────────

enum CalendarEventStatus {
  CONFIRMED
  TENTATIVE
  CANCELLED
}

model CalendarSource {
  id            String          @id @default(cuid())
  name          String
  url           String
  enabled       Boolean         @default(true)
  lastFetchedAt DateTime?       @map("last_fetched_at")
  lastError     String?         @map("last_error")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  events        CalendarEvent[]

  @@map("calendar_sources")
}

model CalendarEvent {
  id                String              @id @default(cuid())
  sourceId          String?             @map("source_id")
  externalId        String              @map("external_id")
  summary           String
  description       String?
  rawSummary        String?             @map("raw_summary")
  rawLocationText   String?             @map("raw_location_text")
  rawDescription    String?             @map("raw_description")
  startsAt          DateTime            @map("starts_at")
  endsAt            DateTime            @map("ends_at")
  allDay            Boolean             @default(false) @map("all_day")
  status            CalendarEventStatus @default(CONFIRMED)
  locationId        String?             @map("location_id")
  sportCode         String?             @map("sport_code")
  isHome            Boolean?            @map("is_home")
  isHidden          Boolean             @default(false) @map("is_hidden")
  opponent          String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  source            CalendarSource?     @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  location          Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  bookings          Booking[]
  bookingLinks      BookingEvent[]
  shiftGroup        ShiftGroup?
  travelMembers     EventTravelMember[]

  @@unique([sourceId, externalId])
  @@index([startsAt, endsAt])
  @@index([locationId])
  @@index([sportCode])
  @@map("calendar_events")
}

model BookingEvent {
  id        String        @id @default(cuid())
  bookingId String        @map("booking_id")
  eventId   String        @map("event_id")
  ordinal   Int
  createdAt DateTime      @default(now()) @map("created_at")
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([bookingId, eventId])
  @@index([eventId])
  @@index([bookingId, ordinal])
  @@map("booking_events")
}

model LocationMapping {
  id         String   @id @default(cuid())
  pattern    String
  locationId String   @map("location_id")
  priority   Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  location   Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("location_mappings")
}

// ── Notifications ────────────────────────────────────────

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum DevicePlatform {
  IOS
  ANDROID

  @@map("device_platform")
}

model DeviceToken {
  id          String         @id @default(cuid())
  userId      String         @map("user_id")
  token       String         @unique
  platform    DevicePlatform @default(IOS)
  appVersion  String?        @map("app_version")
  lastSeenAt  DateTime       @default(now()) @map("last_seen_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  revokedAt   DateTime?      @map("revoked_at")
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@map("device_tokens")
}

model Notification {
  id         String              @id @default(cuid())
  userId     String              @map("user_id")
  type       String
  title      String
  body       String?
  payload    Json?
  channel    NotificationChannel @default(IN_APP)
  sentAt     DateTime?           @map("sent_at")
  readAt     DateTime?           @map("read_at")
  dedupeKey  String?             @unique @map("dedupe_key")
  createdAt  DateTime            @default(now()) @map("created_at")
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model EscalationRule {
  id               String   @id @default(cuid())
  hoursFromDue     Int      @map("hours_from_due")
  type             String   @unique
  title            String
  notifyRequester  Boolean  @default(true) @map("notify_requester")
  notifyAdmins     Boolean  @default(false) @map("notify_admins")
  enabled          Boolean  @default(true)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@map("escalation_rules")
}

// ── Favorites ───────────────────────────────────────────

model FavoriteItem {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  assetId   String   @map("asset_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([userId, assetId])
  @@index([userId])
  @@map("favorite_items")
}

model AllowedEmail {
  id          String    @id @default(cuid())
  email       String    @unique
  role        Role      @default(STUDENT)
  createdById String    @map("created_by_id")
  claimedAt   DateTime? @map("claimed_at")
  claimedById String?   @map("claimed_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdBy   User      @relation("AllowedEmailCreator", fields: [createdById], references: [id], onDelete: Restrict)
  claimedBy   User?     @relation("AllowedEmailClaimer", fields: [claimedById], references: [id], onDelete: SetNull)

  @@index([createdById])
  @@map("allowed_emails")
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// ── Photo Mechanic License Codes ─────────────────────────

enum LicenseCodeStatus {
  AVAILABLE
  PARTIAL
  CLAIMED
  RETIRED
}

model LicenseCode {
  id           String            @id @default(cuid())
  code         String            @unique
  label        String?
  accountEmail String?           @map("account_email")
  expiresAt    DateTime?         @map("expires_at")
  status       LicenseCodeStatus @default(AVAILABLE)
  claimedById  String?           @map("claimed_by_id")
  claimedAt    DateTime?         @map("claimed_at")
  nagSentAt    DateTime?         @map("nag_sent_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  createdById  String?           @map("created_by_id")
  claimedBy    User?             @relation("LicenseClaimedBy", fields: [claimedById], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("LicenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  claims       LicenseCodeClaim[]

  @@index([status])
  @@index([claimedById])
  @@index([expiresAt])
  @@map("license_codes")
}

model LicenseCodeClaim {
  id             String      @id @default(cuid())
  licenseCodeId  String      @map("license_code_id")
  userId         String?     @map("user_id")
  occupantLabel  String?     @map("occupant_label")
  claimedAt      DateTime    @default(now()) @map("claimed_at")
  releasedAt     DateTime?   @map("released_at")
  releasedById   String?     @map("released_by_id")
  notes          String?
  licenseCode    LicenseCode @relation(fields: [licenseCodeId], references: [id], onDelete: Cascade)
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, releasedAt])
  @@index([licenseCodeId])
  @@map("license_code_claims")
}

// ── Shift Calendar & Scheduling ─────────────────────────

enum ShiftArea {
  VIDEO
  PHOTO
  GRAPHICS
  COMMS
}

enum ShiftWorkerType {
  FT
  ST
}

enum ShiftAssignmentStatus {
  DIRECT_ASSIGNED
  REQUESTED
  APPROVED
  DECLINED
  SWAPPED
}

enum ShiftTradeStatus {
  OPEN
  CLAIMED
  APPROVED
  COMPLETED
  CANCELLED
}

model SportConfig {
  id              String             @id @default(cuid())
  sportCode       String             @unique @map("sport_code")
  active          Boolean            @default(true)
  shiftStartOffset Int               @default(60) @map("shift_start_offset")
  shiftEndOffset   Int               @default(60) @map("shift_end_offset")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  shiftConfigs SportShiftConfig[]

  @@map("sport_configs")
}

model SportShiftConfig {
  id            String      @id @default(cuid())
  sportConfigId String      @map("sport_config_id")
  area          ShiftArea
  homeCount     Int         @default(1) @map("home_count")
  awayCount     Int         @default(1) @map("away_count")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  sportConfig   SportConfig @relation(fields: [sportConfigId], references: [id], onDelete: Cascade)

  @@unique([sportConfigId, area])
  @@map("sport_shift_configs")
}

model ShiftGroup {
  id              String        @id @default(cuid())
  eventId         String        @unique @map("event_id")
  isPremier       Boolean       @default(false) @map("is_premier")
  notes           String?
  generatedAt     DateTime?     @map("generated_at")
  manuallyEdited  Boolean       @default(false) @map("manually_edited")
  archivedAt      DateTime?     @map("archived_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  event           CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  shifts          Shift[]

  @@map("shift_groups")
}

model Shift {
  id           String          @id @default(cuid())
  shiftGroupId String          @map("shift_group_id")
  area         ShiftArea
  workerType   ShiftWorkerType @map("worker_type")
  startsAt     DateTime        @map("starts_at")
  endsAt       DateTime        @map("ends_at")
  notes        String?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  shiftGroup   ShiftGroup      @relation(fields: [shiftGroupId], references: [id], onDelete: Cascade)
  assignments  ShiftAssignment[]

  @@index([shiftGroupId])
  @@index([area, workerType])
  @@index([startsAt, endsAt])
  @@map("shifts")
}

model ShiftAssignment {
  id           String                @id @default(cuid())
  shiftId      String                @map("shift_id")
  userId       String                @map("user_id")
  status       ShiftAssignmentStatus
  assignedBy   String?               @map("assigned_by")
  swapFromId   String?               @map("swap_from_id")
  notes        String?
  hasConflict  Boolean               @default(false) @map("has_conflict")
  conflictNote String?               @map("conflict_note")
  attended     Boolean?              // null=unlogged, true=attended, false=no-show
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  shift      Shift                 @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user       User                  @relation("ShiftAssignee", fields: [userId], references: [id], onDelete: Restrict)
  assigner   User?                 @relation("ShiftAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)
  swapFrom   ShiftAssignment?      @relation("ShiftSwap", fields: [swapFromId], references: [id], onDelete: SetNull)
  swappedTo  ShiftAssignment[]     @relation("ShiftSwap")
  trades     ShiftTrade[]
  bookings   Booking[]

  @@index([shiftId, status])
  @@index([userId, status])
  @@map("shift_assignments")
}

model StudentSportAssignment {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  sportCode       String   @map("sport_code")
  defaultTraveler Boolean  @default(false) @map("default_traveler")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sportCode])
  @@index([sportCode])
  @@map("student_sport_assignments")
}

model StudentAreaAssignment {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  area      ShiftArea
  isPrimary Boolean   @default(false) @map("is_primary")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, area])
  @@index([area])
  @@map("student_area_assignments")
}

model ShiftTrade {
  id                String             @id @default(cuid())
  shiftAssignmentId String             @map("shift_assignment_id")
  postedByUserId    String             @map("posted_by_user_id")
  claimedByUserId   String?            @map("claimed_by_user_id")
  status            ShiftTradeStatus   @default(OPEN)
  requiresApproval  Boolean            @default(false) @map("requires_approval")
  notes             String?
  postedAt          DateTime           @default(now()) @map("posted_at")
  claimedAt         DateTime?          @map("claimed_at")
  resolvedAt        DateTime?          @map("resolved_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  shiftAssignment   ShiftAssignment    @relation(fields: [shiftAssignmentId], references: [id], onDelete: Cascade)
  postedBy          User               @relation("TradePostedBy", fields: [postedByUserId], references: [id], onDelete: Restrict)
  claimedBy         User?              @relation("TradeClaimedBy", fields: [claimedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([postedByUserId])
  @@index([claimedByUserId])
  @@map("shift_trades")
}

model StudentAvailabilityBlock {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  dayOfWeek     Int      @map("day_of_week")    // 0=Sun, 1=Mon … 6=Sat
  startsAt      String   @map("starts_at")      // "09:00" HH:mm local time
  endsAt        String   @map("ends_at")        // "11:00" HH:mm local time
  label         String?                          // e.g. "CHEM 101"
  semesterLabel String?  @map("semester_label") // e.g. "Spring 2026"
  createdAt     DateTime @default(now()) @map("created_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("student_availability_blocks")
}

model BookingPhoto {
  id        String    @id @default(cuid())
  bookingId String    @map("booking_id")
  phase     ScanPhase
  imageUrl  String    @map("image_url")
  actorId   String    @map("actor_id")
  createdAt DateTime  @default(now()) @map("created_at")

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor     User      @relation("BookingPhotoActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([bookingId, phase])
  @@map("booking_photos")
}

model CheckinItemReport {
  id           String             @id @default(cuid())
  bookingId    String             @map("booking_id")
  assetId      String             @map("asset_id")
  type         CheckinReportType
  description  String?
  reportedById String             @map("reported_by_id")
  createdAt    DateTime           @default(now()) @map("created_at")

  booking      Booking            @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  asset        Asset              @relation(fields: [assetId], references: [id], onDelete: Restrict)
  reportedBy   User               @relation("CheckinReports", fields: [reportedById], references: [id], onDelete: Restrict)

  @@unique([bookingId, assetId])
  @@index([bookingId])
  @@map("checkin_item_reports")
}

// ── Kiosk Device ─────────────────────────────────────────

model KioskDevice {
  id              String    @id @default(cuid())
  name            String                           // "Video Office iPad"
  locationId      String    @map("location_id")
  activationCode  String    @unique @map("activation_code") // hashed 6-digit code
  activatedAt     DateTime? @map("activated_at")
  sessionToken    String?   @unique @map("session_token")   // hashed long-lived token
  lastSeenAt      DateTime? @map("last_seen_at")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  location        Location  @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([locationId])
  @@map("kiosk_devices")
}

// ── Guides ────────────────────────────────────────────────

model Guide {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  category  String
  content   Json
  published Boolean  @default(false)
  order     Int      @default(0)
  authorId  String   @map("author_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([category])
  @@index([published])
  @@map("guides")
}

// ── Away Travel Roster ────────────────────────────────────

model EventTravelMember {
  id        String        @id @default(cuid())
  eventId   String        @map("event_id")
  userId    String        @map("user_id")
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  event     CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User          @relation("TravelMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_travel_members")
}

{
  "name": "creative-ops",
  "version": "2026.04.08.1",
  "private": true,
  "overrides": {
    "postcss": "$postcss"
  },
  "scripts": {
    "dev": "next dev",
    "postinstall": "prisma generate",
    "build": "node scripts/prisma-migrate-deploy.mjs && next build",
    "migrate": "node scripts/prisma-migrate-deploy.mjs",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:migrate:new": "prisma migrate dev",
    "db:migrate:raw": "prisma migrate dev --create-only",
    "db:migrate:status": "node scripts/prisma-migrate-health.mjs",
    "db:migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "db:migrate:health": "node scripts/prisma-migrate-health.mjs",
    "db:migrate:check": "node scripts/check-migration-prefixes.mjs",
    "db:check:dupe-allocations": "node --env-file=.env scripts/check-dupe-allocations.mjs",
    "db:setup": "node --env-file=.env scripts/setup-db.mjs",
    "db:seed": "node prisma/seed.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "import:cheqroom": "node scripts/import-cheqroom-items.mjs",
    "release": "bash scripts/release.sh",
    "drift:ios": "bash scripts/ios-drift-check.sh",
    "drift:ios:warn": "bash scripts/ios-drift-check.sh --warn",
    "audit:ios": "bash scripts/ios-audit-inventory.sh",
    "audit:ios:gaps": "bash scripts/ios-audit-inventory.sh --gaps"
  },
  "dependencies": {
    "@fontsource/barlow": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@mdxeditor/editor": "^4.0.0",
    "@neondatabase/serverless": "1.1.0",
    "@prisma/adapter-neon": "^6.19.3",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-progress": "^1.1.8",
    "@sentry/nextjs": "^10.53.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@tanstack/query-sync-storage-persister": "^5.100.11",
    "@tanstack/react-query": "^5.100.11",
    "@tanstack/react-query-persist-client": "^5.100.11",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/blob": "^2.4.0",
    "barcode-detector": "^3.1.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.2.1",
    "geist": "^1.7.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.39.0",
    "next": "^15.5.16",
    "postcss": "^8.5.10",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.19.17",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "prisma": "^6.19.3",
    "typescript": "5.9.3",
    "vitest": "^3.0.6"
  }
}
